# Example environment variables for docker-first demo
# Copy to .env and edit as needed: cp .env.example .env

# General
MOCK_MODE=true
SECRET_KEY=replace-me-with-secure-value
MAX_CONCURRENT_CALLS=1
AI_TOKEN_LIMIT=2048
MAX_GEMINI_RESPONSE_TOKENS=512
MESSAGE_DELAY_MS=100
RESPONSE_DELAY_MS=250

# Database: choose sqlite or postgres. Default mocked to sqlite.
DB_PROVIDER=sqlite
SQLITE_PATH=/data/dev.db

# Postgres (optional) - only used when DB_PROVIDER=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=voice_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Store raw audio
STORE_RAW_AUDIO=false
RECORDINGS_PATH=/data/recordings

# Ngrok (optional) - leave empty to run ngrok on host
NGROK_AUTH_TOKEN=
NGROK_REGION=us

# Logging / ports
BACKEND_PORT=8000
METRICS_PORT=9000

# Provider tokens (mocked unless set)
AI_PROVIDER_API_KEY=
TWILIO_AUTH_TOKEN=

# Other
PYTHON_ENV=production
